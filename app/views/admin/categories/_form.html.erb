<%= form_with model: [:admin, category], class: "mt-3" do |f| %>
  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>
  <div>
    <%= f.submit class: "btn btn-dark" %>
    <%= link_to "Back", admin_categories_path, class: "btn btn-outline-dark ms-2" %>
  </div>
<% end %>
