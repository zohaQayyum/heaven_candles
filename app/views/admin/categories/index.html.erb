<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Admin — Categories</h1>
  <%= link_to "New Category", new_admin_category_path, class: "btn btn-dark" %>
</div>

<table class="table table-hover table-bordered">
  <thead class="table-dark">
    <tr>
      <th>Name</th>
      <th>Products Count</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @categories.each do |category| %>
      <tr>
        <td><%= category.name %></td>
        <td><span class="badge bg-secondary"><%= category.products.count %> products</span></td>
        <td>
          <%= link_to "Edit", edit_admin_category_path(category), class: "btn btn-sm btn-outline-dark me-1" %>
          <%= button_to "Delete", admin_category_path(category), method: :delete, class: "btn btn-sm btn-danger", data: { turbo_confirm: "Are you sure?", turbo: false } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="d-flex justify-content-center mt-4 mb-4">
  <%= paginate @categories %>
</div>
