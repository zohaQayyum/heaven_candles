<%= form_with model: [:admin, coupon], class: "mt-3" do |f| %>
  <div class="mb-3">
    <%= f.label :code, class: "form-label" %>
    <%= f.text_field :code, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :discount_type, class: "form-label" %>
    <%= f.select :discount_type, Coupon.discount_types.keys.map { |d| [d.capitalize, d] }, 
        { prompt: "Select type" }, 
        { class: "form-select" } %>
  </div>

  <div class="mb-3">
    <%= f.label :discount_value, class: "form-label" %>
    <%= f.number_field :discount_value, step: 0.01, min: 0, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :expires_at, class: "form-label" %>
    <%= f.datetime_local_field  :expires_at, class: "form-control" %>
  </div>

  <div class="mb-3 form-check">
    <%= f.check_box :active, class: "form-check-input" %>
    <%= f.label :active, class: "form-check-label" %>
  </div>

  <div>
    <%= f.submit class: "btn btn-dark" %>
    <%= link_to "Back", admin_coupons_path, class: "btn btn-outline-dark ms-2" %>
  </div>
<% end %>
