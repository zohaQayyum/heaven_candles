<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Admin — Coupons</h1>
  <%= link_to "New Coupon", new_admin_coupon_path, class: "btn btn-dark" %>
</div>

<table class="table table-hover table-bordered">
  <thead class="table-dark">
    <tr>
      <th>Code</th>
      <th>Discount Type</th>
      <th>Discount Value</th>
      <th>Expires At</th>
      <th>Active</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @coupons.each do |coupon| %>
      <tr>
        <td><%= coupon.code %></td>
        <td><%= coupon.discount_type.capitalize %></td>
        <td><%= coupon.discount_type == 'percentage' ? "#{coupon.discount_value.to_i}%" : "Rs. #{coupon.discount_value}" %></td>
        <td><%= coupon.expires_at&.strftime("%b %d, %Y") || "No expiry" %></td>
        <td><%= coupon.active ? '<span class="badge bg-success">Active</span>'.html_safe : '<span class="badge bg-danger">Inactive</span>'.html_safe %></td>
        <td>
          <%= link_to "Edit", edit_admin_coupon_path(coupon), class: "btn btn-sm btn-outline-dark me-1" %>
          <%= button_to "Delete", admin_coupon_path(coupon), method: :delete, class: "btn btn-sm btn-danger", data: { turbo_confirm: "Are you sure?", turbo: false } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
