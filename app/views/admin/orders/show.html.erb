<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Order — <%= @order.order_number %></h1>
  <%= link_to "← Back to Orders", admin_orders_path, class: "btn btn-outline-secondary" %>
</div>

<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Order Details</h5>
      </div>
      <div class="card-body">
        <table class="table table-bordered">
          <thead class="table-dark">
            <tr>
              <th>Product</th>
              <th>Size</th>
              <th>Qty</th>
              <th>Price</th>
              <th>Status</th>
              <th>Subtotal</th>
            </tr>
          </thead>
          <tbody>
            <% @order.order_items.each do |item| %>
              <tr>
                <td><%= item.product_name %></td>
                <td><%= item.size.capitalize %></td>
                <td><%= item.quantity %></td>
                <td>$<%= item.unit_price %></td>
                <td>
                  <div class="mb-3">
                    <%= form_with url: admin_order_path(@order), 
                      method: :patch, 
                      scope: :order,
                      local: true do |f| %>
                    <%= f.select :status, 
                        Order.statuses.keys.map { |s| [s.capitalize, s] },
                        { selected: @order.status },
                        { class: "form-select form-select-sm", style: "width: 160px;",
                          onchange: "this.form.submit()" } %>
                    <% end %>
                  </div>
                </td>
                <td>$<%= item.total_price %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
        <div class="d-flex justify-content-end">
          <h5>Total: <span class="text-success">$<%= @order.total_amount %></span></h5>
        </div>
      </div>
    </div>

    <div class="card shadow-sm mb-4">
      <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Shipping Information</h5>
      </div>
      <div class="card-body">
        <p><strong>Name:</strong> <%= @order.shipping_name %></p>
        <p><strong>Phone:</strong> <%= @order.shipping_phone %></p>
        <p><strong>Address:</strong> <%= @order.shipping_address %></p>
        <p><strong>City:</strong> <%= @order.shipping_city %></p>
      </div>
    </div>
  </div>
</div>
