<% form_url = product_variant.persisted? ? 
                admin_product_variant_path(@product, product_variant) : 
                admin_product_variants_path(@product) %>

<% form_method = product_variant.persisted? ? :patch : :post %>

<%= form_with model: product_variant, url: form_url, method: form_method, class: "mt-3" do |f| %>

  <% if product_variant.errors.any? %>
    <div class="alert alert-danger">
      <% product_variant.errors.full_messages.each do |msg| %>
        <p class="mb-0"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :size, class: "form-label" %>
    <%= f.select :size, ProductVariant.sizes.keys.map { |s| [s.capitalize, s] }, 
        { prompt: "Select size" }, 
        { class: "form-select" } %>
  </div>

  <div class="mb-3">
    <%= f.label :price, class: "form-label" %>
    <%= f.number_field :price, step: 0.01, min: 0, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :stock, class: "form-label" %>
    <%= f.number_field :stock, min: 0, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :sku, class: "form-label" %>
    <%= f.text_field :sku, class: "form-control" %>
  </div>

  <div>
    <%= f.submit class: "btn btn-dark" %>
    <%= link_to "Back", admin_product_variants_path(@product), class: "btn btn-outline-dark ms-2" %>
  </div>
<% end %>
