<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Variants — <%= @product.name %></h1>
  <%= link_to "New Variant", new_admin_product_variant_path(@product), class: "btn btn-dark" %>
</div>

<table class="table table-hover table-bordered">
  <thead class="table-dark">
    <tr>
      <th>Size</th>
      <th>Price</th>
      <th>Stock</th>
      <th>SKU</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @variants.each do |variant| %>
      <tr>
        <td><span class="badge bg-secondary"><%= variant.size.capitalize %></span></td>
        <td class="text-success fw-bold">Rs.<%= variant.price %></td>
        <td>
          <% if variant.stock == 0 %>
            <span class="badge bg-danger">Out of Stock</span>
          <% else %>
            <span class="badge bg-success"><%= variant.stock %> available</span>
          <% end %>
        </td>
        <td><code><%= variant.sku %></code></td>
        <td>
          <%= link_to "Edit", edit_admin_product_variant_path(@product, variant), class: "btn btn-sm btn-outline-dark me-1" %>
          <%= button_to "Delete", admin_product_variant_path(@product, variant), method: :delete, class: "btn btn-sm btn-danger", data: { turbo_confirm: "Are you sure?", turbo: false } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to "← Back to Products", admin_products_path, class: "btn btn-outline-dark mt-2" %>
