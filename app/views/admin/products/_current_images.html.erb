<div class="mb-3">
  <label class="form-label">Current Images</label>
  <div class="d-flex gap-2 mb-2 flex-wrap">
    <% product.images.each do |image| %>
      <div class="position-relative" style="display: inline-block;">
        <%= image_tag image, class: "img-thumbnail", style: "height: 100px; object-fit: cover;" %>
        <%= button_to "✕", remove_image_admin_product_path(product, image_id: image.id),
            method: :delete,
            class: "btn btn-danger btn-sm position-absolute top-0 end-0",
            style: "line-height: 1;",
            data: { turbo_confirm: "Remove this image?", turbo: false } %>
      </div>
    <% end %>
  </div>
  <small class="text-muted">Click ✕ to remove. Upload new ones in the form below.</small>
</div>
