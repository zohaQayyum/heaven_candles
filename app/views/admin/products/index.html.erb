<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Admin — Products</h1>
  <%= link_to "New Product", new_admin_product_path, class: "btn btn-dark me-2" %>
</div>

<table class="table table-hover table-bordered">
  <thead class="table-dark">
    <tr>
      <th>Name</th>
      <th>Category</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @products.each do |product| %>
      <tr>
        <td><%= product.name %></td>
        <td><span class="badge bg-secondary"><%= product.category_name %></span></td>
        <td>
          <%= link_to "Edit", edit_admin_product_path(product), class: "btn btn-sm btn-outline-dark me-1" %>
          <%= link_to "Variants", admin_product_variants_path(product), class: "btn btn-sm btn-outline-secondary me-1" %>
          <%= button_to "Delete", admin_product_path(product), method: :delete, class: "btn btn-sm btn-danger", data: { turbo_confirm: "Are you sure?", turbo: false } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="d-flex justify-content-center mt-4 mb-4">
  <%= paginate @products %>
</div>
