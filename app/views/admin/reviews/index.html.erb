<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Admin — Reviews</h1>
</div>

<%= form_with url: admin_reviews_path, method: :get, class: "mb-4 d-flex gap-2 align-items-center justify-content-end" do |f| %>
  <%= f.collection_select :product_id, @products, :id, :name,
      { include_blank: "All Products", selected: params[:product_id] },
      { class: "form-select form-select-sm", style: "width: 200px;", onchange: "this.form.submit()" } %>

  <%= f.select :status, 
    [["Pending", "pending"], ["Approved", "approved"], ["Rejected", "rejected"]],
    { include_blank: "All Statuses", selected: params[:status] },
    { class: "form-select form-select-sm", style: "width: 160px;", onchange: "this.form.submit()" } %>

<% end %>

<table class="table table-hover table-bordered">
  <thead class="table-dark">
    <tr>
      <th>Product Name</th>
      <th>Reviewer Name</th>
      <th>Rating</th>
      <th>Comment</th>
      <th>Status</th>
      <th>Action</th>
    </tr>
  </thead>
  <tbody>
    <% @reviews.each do |review| %>
      <tr>
        <td><%= review.product.name %></td>
        <td><%= review.user&.name || review.guest_name %></td>
        <td><%= "⭐" * review.rating %></td>
        <td><%= truncate(review.comment, length: 50) %></td>
        <td>
          <span class="badge <%= review.status == 'approved' ? 'bg-success' : review.status == 'rejected' ? 'bg-danger' : 'bg-warning text-dark' %>">
          <%= review.status.capitalize %>
          </span>
        </td>
        <td>
          <div class="d-flex gap-1">
            <%= link_to "View", admin_review_path(review), class: "btn btn-outline-dark btn-sm" %>
            <%= button_to "Approve", admin_review_path(review.id), method: :patch, params: { status: "approved" }, class: "btn btn-success btn-sm me-1" %>
            <%= button_to "Reject", admin_review_path(review.id), method: :patch, params: { status: "rejected" }, class: "btn btn-danger btn-sm" %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="d-flex justify-content-center mt-4 mb-4">
  <%= paginate @reviews %>
</div>
