<h1 class="mb-4">🛒 Your Cart</h1>

<% if @cart_items.empty? %>
  <div class="text-center py-5">
    <p class="lead text-muted">Your cart is empty.</p>
    <%= link_to "Continue Shopping", products_path, class: "btn btn-dark" %>
  </div>
<% else %>
  <table class="table table-bordered align-middle">
    <thead class="table-dark">
      <tr>
        <th>Product</th>
        <th>Size</th>
        <th>Price</th>
        <th>Quantity</th>
        <th>Subtotal</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% @cart_items.each do |item| %>
        <tr>
          <td><strong><%= item.product_variant.product.name %></strong></td>
          <td><%= item.product_variant.size.capitalize %></td>
          <td>Rs.<%= item.product_variant.price %></td>
          <td>
            <%= button_to "-", decrement_cart_path(item.id), method: :patch, class: "btn btn-outline-dark btn-sm", data: { turbo: false } %>
            <span class="mx-2"><%= item.quantity %></span>
            <%= button_to "+", increment_cart_path(item.id), method: :patch, class: "btn btn-outline-dark btn-sm", data: { turbo: false } %>
          </td>
          <td class="text-success fw-bold">Rs.<%= (item.product_variant.price * item.quantity).round(2) %></td>
          <td>
            <%= button_to "Remove", remove_from_cart_path(item.id), method: :delete, class: "btn btn-danger btn-sm", data: { turbo: false } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="d-flex justify-content-end mt-3">
    <h4>Total: <span class="text-success">Rs.<%= @total.round(2) %></span></h4>
  </div>

  <div class="d-flex justify-content-between mt-3">
    <%= link_to "← Continue Shopping", products_path, class: "btn btn-outline-dark" %>
    <%= link_to "Checkout →", new_order_path, class: "btn btn-dark" %>
  </div>
<% end %>
