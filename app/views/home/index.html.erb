<div class="text-center py-5">
  <h1 class="display-4 fw-bold">🕯️ Welcome to Heaven Candles</h1>
  <p class="lead text-muted">Handcrafted candles for every mood and moment</p>
  <% if user_signed_in? %>
    <p class="fs-5">Welcome back, <strong><%= current_user.name %></strong>!</p>
    <%= link_to "Shop Now", products_path, class: "btn btn-dark btn-lg mt-2" %>
  <% else %>
    <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-dark btn-lg mt-2 me-2" %>
    <%= link_to "Sign In", new_user_session_path, class: "btn btn-outline-dark btn-lg mt-2" %>
  <% end %>
</div>
