<!DOCTYPE html>
<html>
  <head>
    <title>Admin | <%= content_for(:title) || "Heaven Candles" %></title>
    <%= render "layouts/head" %>
  </head>
  <body>
    <div class="container-fluid p-0">
      <div class="row g-0 min-vh-100">
        
        <!-- Sidebar -->
        <div class="col-md-2 bg-dark text-white d-flex flex-column p-3">
          <div class="mb-3 border-bottom border-secondary pb-3">
            <%= link_to "🕯️ Heaven Candles", admin_products_path, class: "text-white text-decoration-none fs-5 fw-bold" %>
            <div class="text-muted small">Admin Panel</div>
          </div>
          
          <nav class="nav flex-column mt-3">
            <%= admin_nav_link "📦 Products", admin_products_path %>
            <%= admin_nav_link "🏷️ Categories", admin_categories_path %>
            <%= admin_nav_link "📋 Orders", admin_orders_path %>
            <%= admin_nav_link "🎟️ Coupons", admin_coupons_path %>
          </nav>

          <div class="mt-auto border-top border-secondary pt-3">
            <%= link_to "← Back to Site", products_path, class: "nav-link text-white-50" %>
          </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-10 p-4">
          <% if notice %>
            <div class="alert alert-success alert-dismissible"><%= notice %></div>
          <% end %>
          <% if alert %>
            <div class="alert alert-danger alert-dismissible"><%= alert %></div>
          <% end %>
          <%= yield %>
        </div>
      </div>
    </div>
  </body>
</html>
