<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "Heaven Candles" %></title>
    <meta name="description" content="<%= content_for?(:description) ? yield(:description) : 'Premium handmade candles — shop our collection of beautifully crafted scented candles.' %>">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <%= render "layouts/head" %>
  </head>
  <body>
    <%= render "shared/navbar" %>
    <% if notice %>
      <div class="container mt-2">
        <div class="alert alert-success alert-dismissible"><%= notice %></div>
      </div>
    <% end %>
    <% if alert %>
      <div class="alert alert-danger alert-dismissible"><%= alert %></div>
    <% end %>
    <% if content_for?(:full_width_header) %>
      <%= yield :full_width_header %>
    <% end %>

    <div class="container mt-4">
      <%= yield %>
    </div>

    <%= render "shared/footer" %>
  </body>
</html>
