<!DOCTYPE html>
<html>
  <head>
    <title>Heaven Candles</title>
    <%= render "layouts/head" %>
  </head>
  <body>
    <%= render "shared/navbar" %>
    <% if notice %>
      <div class="alert alert-success alert-dismissible"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div class="alert alert-danger alert-dismissible"><%= alert %></div>
    <% end %>
    <% if content_for?(:full_width_header) %>
      <%= yield :full_width_header %>
    <% end %>

    <div class="container mt-4">
      <%= yield %>
    </div>

    <%= render "shared/footer" %>
  </body>
</html>
