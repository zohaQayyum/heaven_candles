<h1 class="mb-4">My Orders</h1>

<% if @orders.empty? %>
  <div class="text-center py-5">
    <p class="lead text-muted">You have not placed any orders yet.</p>
    <%= link_to "Start Shopping", products_path, class: "btn btn-dark" %>
  </div>
<% else %>
  <table class="table table-hover table-bordered">
    <thead class="table-dark">
      <tr>
        <th>Order Number</th>
        <th>Date</th>
        <th>Items</th>
        <th>Total</th>
        <th>Status</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% @orders.each do |order| %>
        <tr>
          <td><strong><%= order.order_number %></strong></td>
          <td><%= order.created_at.strftime("%B %d, %Y") %></td>
          <td><%= order.order_items.count %> items</td>
          <td class="text-success fw-bold">Rs.<%= order.total_amount %></td>
          <td> 
            <span class="badge <%= order_status_badge_class(order.status) %>">
              <%= order.status.capitalize %>
            </span>
          </td>
          <td><%= link_to "View", order_path(order), class: "btn btn-sm btn-outline-dark" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<div class="d-flex justify-content-center mt-4 mb-4">
  <%= paginate @orders %>
</div>
