<div class="row">
  <div class="col-md-7">
    <h2 class="mb-4">Checkout</h2>

    <%= form_with model: @order, url: orders_path, class: "mt-3" do |f| %>
      <% if @order.errors.any? %>
        <div class="alert alert-danger">
          <% @order.errors.full_messages.each do |msg| %>
            <p class="mb-0"><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <h5 class="mb-3">Shipping Information</h5>

      <div class="mb-3">
        <%= f.label :shipping_name, "Full Name", class: "form-label" %>
        <%= f.text_field :shipping_name, class: "form-control", placeholder: "Zoha Qayyum" %>
      </div>
      
      <div class="mb-3">
        <%= f.label :shipping_email, "Email Address" %>
        <%= f.email_field :shipping_email, 
            class: "form-control",
            placeholder: 'your@email.com' %>
        <small class="text-muted">We'll send your order confirmation here</small>
      </div>

      <div class="mb-3">
        <%= f.label :shipping_phone, "Phone Number", class: "form-label" %>
        <%= f.text_field :shipping_phone, class: "form-control", placeholder: "+92 300 0000000" %>
      </div>

      <div class="mb-3">
        <%= f.label :shipping_address, "Address", class: "form-label" %>
        <%= f.text_area :shipping_address, class: "form-control", rows: 3, placeholder: "Street address" %>
      </div>

      <div class="mb-3">
        <%= f.label :shipping_city, "City", class: "form-label" %>
        <%= f.text_field :shipping_city, class: "form-control", placeholder: "Faisalabad" %>
      </div>

      <div class="mb-4">
        <h5 class="mb-3">Payment Method</h5>
        <div class="card border-dark">
          <div class="card-body d-flex align-items-center gap-3">
            <input type="radio" checked disabled>
            <div>
              <strong>💵 Cash on Delivery</strong>
              <p class="text-muted mb-0 small">Pay when your order arrives</p>
            </div>
          </div>
        </div>
      </div>
      <input type="hidden" name="order[coupon_code]" id="form-coupon-code" />
      <%= f.submit "Place Order", class: "btn btn-dark btn-lg w-100 mt-2" %>
    <% end %>
  </div>

  <div class="col-md-5">
    <div class="card shadow-sm">
      <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Order Summary</h5>
      </div>
      <div class="card-body">
        <table class="table table-sm">
          <% total = 0 %>
          <% @cart_items.each do |item| %>
            <% quantity = item.quantity %>
            <% subtotal = item.product_variant.price * quantity %>
            <% total += subtotal %>
            <tr>
              <td>
                <strong><%= item.product_variant.product.name %></strong><br>
                <small class="text-muted"><%= item.product_variant.size.capitalize %> x <%= quantity %></small>
              </td>
              <td class="text-end">Rs.<%= subtotal.round(2) %></td>
            </tr>
          <% end %>
        </table>

        <div data-controller="coupon" class="mb-3" data-coupon-original-total-value="<%= total %>">
          <label class="form-label small text-muted">Have a coupon?</label>
          <div class="input-group">
            <input type="text" 
                  class="form-control form-control-sm" 
                  placeholder="Enter coupon code"
                  data-coupon-target="code" />
            <button type="button" 
                    class="btn btn-outline-dark btn-sm"
                    data-action="click->coupon#apply">Apply</button>
            <button type="button" 
                    class="btn btn-outline-secondary btn-sm"
                    data-action="click->coupon#clear">✕</button>
          </div>
          <span data-coupon-target="discountDisplay" class="small mt-1 d-block"></span>
          <input type="hidden" data-coupon-target="hiddenCode" name="coupon_code" />
          <hr>

          <div class="d-flex justify-content-between">
            <strong>Total</strong>
            <strong class="text-success" data-coupon-target="total">Rs.<%= total.round(2) %></strong>
          </div>
        </div>

      </div>
    </div>
    <%= link_to "← Back to Cart", cart_path, class: "btn btn-outline-dark w-100 mt-3" %>
  </div>
</div>
