<div class="row">
  <div class="col-md-7">
    <h2 class="mb-4">Checkout</h2>

    <%= form_with model: @order, url: orders_path, class: "mt-3" do |f| %>
      <% if @order.errors.any? %>
        <div class="alert alert-danger">
          <% @order.errors.full_messages.each do |msg| %>
            <p class="mb-0"><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <h5 class="mb-3">Shipping Information</h5>

      <div class="mb-3">
        <%= f.label :shipping_name, "Full Name", class: "form-label" %>
        <%= f.text_field :shipping_name, class: "form-control", placeholder: "Zoha Qayyum" %>
      </div>

      <div class="mb-3">
        <%= f.label :shipping_phone, "Phone Number", class: "form-label" %>
        <%= f.text_field :shipping_phone, class: "form-control", placeholder: "+92 300 0000000" %>
      </div>

      <div class="mb-3">
        <%= f.label :shipping_address, "Address", class: "form-label" %>
        <%= f.text_area :shipping_address, class: "form-control", rows: 3, placeholder: "Street address" %>
      </div>

      <div class="mb-3">
        <%= f.label :shipping_city, "City", class: "form-label" %>
        <%= f.text_field :shipping_city, class: "form-control", placeholder: "Faisalabad" %>
      </div>

      <%= f.submit "Place Order", class: "btn btn-dark btn-lg w-100 mt-2" %>
    <% end %>
  </div>

  <div class="col-md-5">
    <div class="card shadow-sm">
      <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Order Summary</h5>
      </div>
      <div class="card-body">
        <table class="table table-sm">
          <% total = 0 %>
          <% @variants.each do |variant| %>
            <% quantity = @cart[variant.id.to_s] %>
            <% subtotal = variant.price * quantity %>
            <% total += subtotal %>
            <tr>
              <td>
                <strong><%= variant.product.name %></strong><br>
                <small class="text-muted"><%= variant.size.capitalize %> x <%= quantity %></small>
              </td>
              <td class="text-end">$<%= subtotal.round(2) %></td>
            </tr>
          <% end %>
        </table>
        <hr>
        <div class="d-flex justify-content-between">
          <strong>Total</strong>
          <strong class="text-success">$<%= total.round(2) %></strong>
        </div>
      </div>
    </div>
    <%= link_to "← Back to Cart", cart_path, class: "btn btn-outline-dark w-100 mt-3" %>
  </div>
</div>
