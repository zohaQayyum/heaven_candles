<div class="text-center mb-4">
  <h1 class="text-success">✅ Order Placed Successfully!</h1>
  <p class="lead">Thank you for your order, <strong><%= current_user&.name || @order.shipping_name %></strong>!</p>
</div>

<div class="alert alert-info mt-3 d-flex justify-content-between align-items-center">
  <span>📋 Save your order number to track it later: <strong><%= @order.order_number %></strong></span>
  <button class="btn btn-sm btn-outline-dark" onclick="navigator.clipboard.writeText('<%= @order.order_number %>'); this.textContent='Copied!'">
    Copy
  </button>
</div>

<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Order Details</h5>
      </div>
      <div class="card-body">
        <table class="table table-bordered">
          <thead class="table-dark">
            <tr>
              <th>Product</th>
              <th>Size</th>
              <th>Qty</th>
              <th>Price</th>
              <th>Subtotal</th>
            </tr>
          </thead>
          <tbody>
            <% @order.order_items.each do |item| %>
              <tr>
                <td><%= item.product_name %></td>
                <td><%= item.size.capitalize %></td>
                <td><%= item.quantity %></td>
                <td>Rs.<%= item.unit_price %></td>
                <td>Rs.<%= item.total_price %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
        <div class="d-flex justify-content-end flex-column align-items-end">
          <% if @order.coupon.present? %>
            <span class="text-success small mb-1">
              Coupon applied: <%= @order.coupon.discount_type == "percentage" ? "#{@order.coupon.discount_value.to_i}% off" : "Rs. #{@order.coupon.discount_value} off" %>
            </span>
          <% end %>
          <h5>Total: <span class="text-success">Rs.<%= @order.total_amount %></span></h5>
        </div>
      </div>
    </div>

    <div class="card shadow-sm mb-4">
      <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Shipping Information</h5>
      </div>
      <div class="card-body">
        <p><strong>Name:</strong> <%= @order.shipping_name %></p>
        <p><strong>Phone:</strong> <%= @order.shipping_phone %></p>
        <p><strong>Address:</strong> <%= @order.shipping_address %></p>
        <p><strong>City:</strong> <%= @order.shipping_city %></p>
      </div>
    </div>

    <div class="d-flex gap-2">
      <% if current_user %>
        <%= link_to "View All Orders", orders_path, class: "btn btn-outline-dark" %>
      <% end %>
      <%= link_to "Continue Shopping", products_path, class: "btn btn-dark" %>
    </div>
  </div>
</div>
