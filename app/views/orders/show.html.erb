<div class="text-center mb-4">
  <h1 class="text-success">✅ Order Placed Successfully!</h1>
  <p class="lead">Thank you for your order, <strong><%= current_user.name %></strong>!</p>
  <p class="text-muted">Order Number: <strong><%= @order.order_number %></strong></p>
</div>

<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Order Details</h5>
      </div>
      <div class="card-body">
        <table class="table table-bordered">
          <thead class="table-dark">
            <tr>
              <th>Product</th>
              <th>Size</th>
              <th>Qty</th>
              <th>Price</th>
              <th>Subtotal</th>
            </tr>
          </thead>
          <tbody>
            <% @order.order_items.each do |item| %>
              <tr>
                <td><%= item.product_name %></td>
                <td><%= item.size.capitalize %></td>
                <td><%= item.quantity %></td>
                <td>$<%= item.unit_price %></td>
                <td>$<%= item.total_price %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
        <div class="d-flex justify-content-end">
          <h5>Total: <span class="text-success">$<%= @order.total_amount %></span></h5>
        </div>
      </div>
    </div>

    <div class="card shadow-sm mb-4">
      <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Shipping Information</h5>
      </div>
      <div class="card-body">
        <p><strong>Name:</strong> <%= @order.shipping_name %></p>
        <p><strong>Phone:</strong> <%= @order.shipping_phone %></p>
        <p><strong>Address:</strong> <%= @order.shipping_address %></p>
        <p><strong>City:</strong> <%= @order.shipping_city %></p>
      </div>
    </div>

    <div class="d-flex gap-2">
      <%= link_to "View All Orders", orders_path, class: "btn btn-outline-dark" %>
      <%= link_to "Continue Shopping", products_path, class: "btn btn-dark" %>
    </div>
  </div>
</div>
