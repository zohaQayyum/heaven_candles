<div class="position-relative mb-5" style="height: 400px; overflow: hidden;">
  <img src="https://res.cloudinary.com/drdt6bbte/image/upload/v1775562923/banner_photo_sptd1q.jpg" 
       alt="Heaven Candles Banner"
       style="width: 100%; height: 100%; object-fit: cover; filter: brightness(0.6);">
  <div class="position-absolute top-50 start-50 translate-middle text-center text-white">
    <h1 class="display-3 fw-bold">Heaven Candles</h1>
    <p class="lead fs-4">Handcrafted scents for every moment</p>
    <a href="#candles" class="btn btn-warning btn-lg mt-2">Shop Now</a>
  </div>
</div>

<div class="container my-3">
  <div class="d-flex justify-content-end gap-2">
    <%= form_with url: products_path, method: :get do |f| %>
      <div class="d-flex gap-2 align-items-center">
        <%= f.collection_select :category_id, @categories, :id, :name,
          { include_blank: "All Categories", selected: params[:category_id] },
          { class: "form-select form-select-sm", style: "width: 160px;", 
            onchange: "this.form.submit()" } %>

        <div class="input-group" style="width: 300px;">
          <%= f.text_field :search,
              value: params[:search],
              placeholder: "Search candles...",
              class: "form-control form-control-sm" %>
          <% if params[:search].present? %>
            <%= link_to "✕", products_path(category_id: params[:category_id]), class: "btn btn-outline-secondary btn-sm" %>
          <% end %>
          <%= f.submit "Search", class: "btn btn-dark btn-sm" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<% if @products.empty? %>
  <div class="text-center py-5">
    <p class="fs-1">🕯️</p>
    <h4 class="text-muted">No candles found</h4>
    <p class="text-muted">Try a different search or category</p>
    <%= link_to "Clear filters", products_path, class: "btn btn-dark btn-sm mt-2" %>
  </div>
<% end %>

<div id="candles"> 
  <% @products.group_by(&:category).each do |category, products| %>
    <h2 class="mt-4 mb-3 border-bottom pb-2"><%= category.name %></h2>
    <div class="row row-cols-1 row-cols-md-3 g-4 mb-4">
      <% products.each do |product| %>
        <div class="card h-100 shadow-sm">
          <% if product.images.attached? %>
            <%= image_tag product.images.first, class: "card-img-top", style: "height: 200px; object-fit: cover;" %>
          <% else %>
            <div class="bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
              <span class="text-muted">🕯️ No image</span>
            </div>
          <% end %>
          <div class="card-body">
            <h5 class="card-title"><%= product.name %></h5>
            <p class="card-text text-muted"><%= product.description %></p>
          </div>
          <div class="card-footer d-flex justify-content-between align-items-center">
            <% if product.starting_price %>
              <span class="text-success fw-bold">From $<%= product.starting_price %></span>
            <% end %>
            <%= link_to "View", product_path(product), class: "btn btn-dark btn-sm" %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
