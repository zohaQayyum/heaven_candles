<h1 class="mb-4">Our Candles</h1>

<% @products.group_by(&:category).each do |category, products| %>
  <h2 class="mt-4 mb-3 border-bottom pb-2"><%= category.name %></h2>
  <div class="row row-cols-1 row-cols-md-3 g-4 mb-4">
    <% products.each do |product| %>
      <div class="col">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <h5 class="card-title"><%= product.name %></h5>
            <p class="card-text text-muted"><%= product.description %></p>
          </div>
          <div class="card-footer d-flex justify-content-between align-items-center">
            <% if product.starting_price %>
              <span class="text-success fw-bold">From $<%= product.starting_price %></span>
            <% end %>
            <%= link_to "View", product_path(product), class: "btn btn-dark btn-sm" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
