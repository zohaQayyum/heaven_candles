<div class="row g-5">
  <div class="col-md-5">
    <% if @product.images.attached? %>
      <% if @product.images.count > 1 %>
        <div id="productCarousel" class="carousel slide" data-bs-ride="carousel">
          <div class="carousel-inner rounded shadow">
            <% @product.images.each_with_index do |image, index| %>
              <div class="carousel-item <%= 'active' if index == 0 %>">
                <%= image_tag image, class: "d-block w-100", style:"height: 400px; object-fit: contain; background-color: #f8f9fa;" %>
              </div>
            <% end %>
          </div>
          <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" style="filter: invert(1);"></span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" style="filter: invert(1);"></span>
          </button>
          <div class="d-flex gap-2 mt-3 flex-wrap">
            <% @product.images.each_with_index do |image, index| %>
              <%= image_tag image, 
                  class: "img-thumbnail", 
                  style: "height: 70px; width: 70px; object-fit: cover; cursor: pointer;",
                  data: { "bs-target": "#productCarousel", "bs-slide-to": index } %>
            <% end %>
          </div>
        </div>
      <% else %>
        <%= image_tag @product.images.first, 
            class: "img-fluid rounded shadow", 
            style:"height: 400px; object-fit: contain; background-color: #f8f9fa;" %>
      <% end %>
    <% else %>
      <div class="bg-light d-flex align-items-center justify-content-center rounded" style="height: 400px;">
        <span class="text-muted fs-1">🕯️</span>
      </div>
    <% end %>
  </div>

  <div class="col-md-7">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Products", products_path %></li>
        <li class="breadcrumb-item active"><%= @product.name %></li>
      </ol>
    </nav>

    <h1 class="mb-2"><%= @product.name %></h1>
    <span class="badge bg-secondary mb-3"><%= @product.category_name %></span>
    <p class="lead text-muted"><%= @product.description %></p>

    <hr>

    <h5 class="mb-3">Select Size</h5>

    <div data-controller="product-variants" 
        data-product-variants-variants-value="<%= @product.product_variants.order(:size).map { |v| {id: v.id, size: v.size, price: v.price, stock: v.stock} }.to_json %>">

      <div class="d-flex gap-2 mb-3">
        <% @product.product_variants.order(:size).each do |variant| %>
          <button type="button"
            class="btn btn-outline-dark <%= 'opacity-50' if variant.stock == 0 %>"
            data-variant-id="<%= variant.id %>"
            data-product-variants-target="option"
            data-action="click->product-variants#getPrice">
            <%= variant.size.capitalize %>
          </button>
        <% end %>
      </div>

      <span class="fs-3 fw-bold text-success" data-product-variants-target="price">—</span>

      <div class="mt-3" data-product-variants-target="cartForm"></div>
    </div>
  </div>
</div>

<hr class="mt-5">
<h4 class="mb-4">Customer Reviews</h4>

<% if @reviews.empty? %>
  <p class="text-muted">No reviews yet. Be the first to review this product!</p>
<% else %>
  <% @reviews.each do |review| %>
    <div class="border-bottom pb-3 mb-3">
      <div class="d-flex justify-content-between">
        <strong><%= review.user&.name || review.guest_name || "Anonymous" %></strong>
        <small class="text-muted"><%= review.created_at.strftime("%b %d, %Y") %></small>
      </div>
      <div class="text-warning">
        <%= "⭐" * review.rating %><%= "☆" * (5 - review.rating) %>
      </div>
      <p class="mt-2 mb-0"><%= review.comment %></p>
    </div>
  <% end %>
<% end %>

<%= form_with url: product_reviews_path(@product), method: :post, scope: :review, class: "mt-3", data: { turbo: false } do |f| %>
  <div class="mb-3">
    <%= f.label :rating, "Rating", class: "form-label" %>
    <div class="d-flex gap-2">
      <% (1..5).each do |star| %>
        <div class="form-check form-check-inline">
          <%= f.radio_button :rating, star, id: "rating_#{star}" %>
          <%= label_tag "rating_#{star}", "⭐ #{star}", class: "form-check-label" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :comment, class: "form-label" %>
    <%= f.text_area :comment, rows: 4, class: "form-control" %>
  </div>

  <% unless current_user %>
    <div class="mb-3">
      <%= f.label :guest_name, class: "form-label" %>
      <%= f.text_field :guest_name, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :guest_email, class: "form-label" %>
      <%= f.text_field :guest_email, class: "form-control" %>
    </div>
  <% end %>

  <div>
    <%= f.submit class: "btn btn-dark" %>
  </div>
<% end %>
